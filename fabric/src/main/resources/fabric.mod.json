{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${mod_version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_authors}"
    ],
    "contact": {
        "homepage": "https://github.com/Fragmented-Chaos/Charm-of-Undying-Reborn",
        "sources": "https://github.com/Fragmented-Chaos/Charm-of-Undying-Reborn",
        "issues": "https://github.com/Fragmented-Chaos/Charm-of-Undying-Reborn/issues"
    },
    "license": "${license}",
    "icon": "assets/${mod_id}/${mod_id}.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.fragmentedchaos.charmofundyingreborn.CharmOfUndyingReborn"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-api": "*",
        "trinkets": ">=${trinkets_version}",
        "minecraft": ">=${minecraft_version}",
        "java": ">=${java_version}"
    }
}
